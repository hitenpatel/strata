{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "n": {
      "0":   { "$type": "color", "$value": "#ffffff" },
      "50":  { "$type": "color", "$value": "#faf8f5" },
      "100": { "$type": "color", "$value": "#f3efe9" },
      "200": { "$type": "color", "$value": "#e7e1d8" },
      "300": { "$type": "color", "$value": "#d6cec1" },
      "400": { "$type": "color", "$value": "#b3a996" },
      "500": { "$type": "color", "$value": "#8c8271" },
      "600": { "$type": "color", "$value": "#6a6153" },
      "700": { "$type": "color", "$value": "#4e463b" },
      "800": { "$type": "color", "$value": "#352f28" },
      "900": { "$type": "color", "$value": "#231f1a" },
      "950": { "$type": "color", "$value": "#15120e" }
    },
    "blue": {
      "50":  { "$type": "color", "$value": "#eef4ff" },
      "400": { "$type": "color", "$value": "#60a5fa" },
      "500": { "$type": "color", "$value": "#3b82f6" },
      "600": { "$type": "color", "$value": "#2563eb" },
      "700": { "$type": "color", "$value": "#1d4ed8" }
    },
    "violet": {
      "50":  { "$type": "color", "$value": "#f4f1ff" },
      "400": { "$type": "color", "$value": "#a78bfa" },
      "500": { "$type": "color", "$value": "#8b5cf6" },
      "600": { "$type": "color", "$value": "#7c3aed" },
      "700": { "$type": "color", "$value": "#6d28d9" }
    },
    "green": {
      "50":  { "$type": "color", "$value": "#eefaf1" },
      "500": { "$type": "color", "$value": "#22c55e" },
      "600": { "$type": "color", "$value": "#16a34a" },
      "700": { "$type": "color", "$value": "#15803d" }
    },
    "amber": {
      "50":  { "$type": "color", "$value": "#fdf6e9" },
      "500": { "$type": "color", "$value": "#f59e0b" },
      "600": { "$type": "color", "$value": "#d97706" },
      "700": { "$type": "color", "$value": "#b45309" }
    },
    "red": {
      "50":  { "$type": "color", "$value": "#fdf0ee" },
      "500": { "$type": "color", "$value": "#ef4444" },
      "600": { "$type": "color", "$value": "#dc2626" },
      "700": { "$type": "color", "$value": "#b91c1c" }
    }
  },
  "font": {
    "body":    { "$type": "fontFamily", "$value": "'Inter', system-ui, sans-serif" },
    "display": { "$type": "fontFamily", "$value": "'Satoshi', 'Inter', system-ui, sans-serif" },
    "mono":    { "$type": "fontFamily", "$value": "'JetBrains Mono', ui-monospace, monospace" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "6px" },
    "lg":   { "$type": "dimension", "$value": "8px" },
    "xl":   { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "offset": {
    "1": { "$type": "dimension", "$value": "2px" },
    "2": { "$type": "dimension", "$value": "4px" },
    "3": { "$type": "dimension", "$value": "6px" }
  },
  "border": {
    "width": { "$type": "dimension", "$value": "1.5px" }
  },
  "duration": {
    "fast":  { "$type": "duration", "$value": "120ms" },
    "base":  { "$type": "duration", "$value": "200ms" },
    "slow":  { "$type": "duration", "$value": "320ms" },
    "press": { "$type": "duration", "$value": "90ms" }
  },
  "easing": {
    "default": { "$type": "cubicBezier", "$value": "cubic-bezier(.22,1.2,.36,1)" },
    "settle":  { "$type": "cubicBezier", "$value": "cubic-bezier(.22,1.2,.36,1)" },
    "drop":    { "$type": "cubicBezier", "$value": "cubic-bezier(.4,0,.6,1)" }
  },
  "semantic": {
    "light": {
      "canvas":              "{color.n.100}",
      "surface":             "#ffffff",
      "surface-raised":      "#ffffff",
      "surface-sunken":      "{color.n.100}",
      "surface-hover":       "{color.n.50}",
      "border":              "{color.n.200}",
      "border-strong":       "{color.n.300}",
      "text":                "{color.n.900}",
      "text-muted":          "{color.n.600}",
      "text-subtle":         "{color.n.500}",
      "accent":              "{color.blue.600}",
      "accent-hover":        "{color.blue.700}",
      "accent-subtle":       "{color.blue.50}",
      "on-accent":           "#ffffff",
      "danger":              "{color.red.600}",
      "danger-hover":        "{color.red.700}",
      "danger-subtle":       "{color.red.50}",
      "on-danger":           "#ffffff",
      "success":             "{color.green.600}",
      "success-subtle":      "{color.green.50}",
      "warning":             "{color.amber.600}",
      "warning-subtle":      "{color.amber.50}",
      "focus-ring":          "{color.blue.600}",
      "layer-shadow":        "{color.n.300}",
      "layer-shadow-accent": "{color.blue.700}",
      "layer-shadow-danger": "{color.red.700}",
      "layer-edge-1":        "{color.n.300}",
      "layer-edge-2":        "{color.n.200}",
      "band-accent":         "{color.blue.600}",
      "band-danger":         "{color.red.600}",
      "band-success":        "{color.green.600}",
      "band-warning":        "{color.amber.600}",
      "band-neutral":        "{color.n.400}",
      "shadow-xs":           "1px 1px 0 0 var(--strata-layer-shadow)",
      "shadow-sm":           "2px 2px 0 0 var(--strata-layer-shadow)",
      "shadow-md":           "4px 4px 0 0 var(--strata-layer-shadow), 0 5px 0 -1px var(--strata-layer-edge-1), 0 8px 0 -2px var(--strata-layer-edge-2)",
      "shadow-lg":           "6px 6px 0 0 var(--strata-layer-shadow), 0 6px 0 -1px var(--strata-layer-edge-1), 0 11px 0 -3px var(--strata-layer-edge-2)"
    },
    "dark": {
      "canvas":              "#15120e",
      "surface":             "#221d18",
      "surface-raised":      "#2c261f",
      "surface-sunken":      "#100c09",
      "surface-hover":       "#2c261f",
      "border":              "#403830",
      "border-strong":       "#544a3e",
      "text":                "{color.n.50}",
      "text-muted":          "{color.n.300}",
      "text-subtle":         "{color.n.400}",
      "accent":              "{color.blue.500}",
      "accent-hover":        "{color.blue.400}",
      "accent-subtle":       "#16233d",
      "on-accent":           "#050d1c",
      "danger":              "{color.red.500}",
      "danger-hover":        "#f87171",
      "danger-subtle":       "#331512",
      "on-danger":           "#1e0806",
      "success":             "{color.green.500}",
      "success-subtle":      "#12251a",
      "warning":             "{color.amber.500}",
      "warning-subtle":      "#2b1f0a",
      "focus-ring":          "{color.blue.400}",
      "layer-shadow":        "#000000",
      "layer-shadow-accent": "{color.blue.700}",
      "layer-shadow-danger": "{color.red.700}",
      "layer-edge-1":        "#403830",
      "layer-edge-2":        "#2c261f",
      "band-accent":         "{color.blue.500}",
      "band-danger":         "{color.red.500}",
      "band-success":        "{color.green.500}",
      "band-warning":        "{color.amber.500}",
      "band-neutral":        "{color.n.500}"
    }
  },
  "variants": {
    "showcase": {
      "light": {
        "accent":              "{color.violet.600}",
        "accent-hover":        "{color.violet.700}",
        "accent-subtle":       "{color.violet.50}",
        "focus-ring":          "{color.violet.600}",
        "layer-shadow-accent": "{color.violet.700}",
        "band-accent":         "{color.violet.600}"
      },
      "dark": {
        "accent":              "{color.violet.400}",
        "accent-hover":        "#c4b5fd",
        "accent-subtle":       "#241640",
        "on-accent":           "#140a2e",
        "focus-ring":          "{color.violet.400}",
        "layer-shadow-accent": "{color.violet.700}",
        "band-accent":         "{color.violet.400}"
      }
    }
  }
}
