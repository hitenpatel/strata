{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "n": {
      "0":   { "$type": "color", "$value": "#ffffff" },
      "50":  { "$type": "color", "$value": "#fafafa" },
      "100": { "$type": "color", "$value": "#f4f4f5" },
      "200": { "$type": "color", "$value": "#e4e4e7" },
      "300": { "$type": "color", "$value": "#d4d4d8" },
      "400": { "$type": "color", "$value": "#a1a1aa" },
      "500": { "$type": "color", "$value": "#71717a" },
      "600": { "$type": "color", "$value": "#52525b" },
      "700": { "$type": "color", "$value": "#3f3f46" },
      "800": { "$type": "color", "$value": "#27272a" },
      "900": { "$type": "color", "$value": "#18181b" },
      "950": { "$type": "color", "$value": "#09090b" }
    },
    "blue": {
      "50":  { "$type": "color", "$value": "#eff6ff" },
      "400": { "$type": "color", "$value": "#60a5fa" },
      "500": { "$type": "color", "$value": "#3b82f6" },
      "600": { "$type": "color", "$value": "#2563eb" },
      "700": { "$type": "color", "$value": "#1d4ed8" },
      "950": { "$type": "color", "$value": "#172554" }
    },
    "violet": {
      "50":  { "$type": "color", "$value": "#f5f3ff" },
      "400": { "$type": "color", "$value": "#a78bfa" },
      "500": { "$type": "color", "$value": "#8b5cf6" },
      "600": { "$type": "color", "$value": "#7c3aed" },
      "700": { "$type": "color", "$value": "#6d28d9" },
      "950": { "$type": "color", "$value": "#2e1065" }
    },
    "green": {
      "50":  { "$type": "color", "$value": "#f0fdf4" },
      "500": { "$type": "color", "$value": "#22c55e" },
      "600": { "$type": "color", "$value": "#16a34a" },
      "700": { "$type": "color", "$value": "#15803d" }
    },
    "amber": {
      "50":  { "$type": "color", "$value": "#fffbeb" },
      "500": { "$type": "color", "$value": "#f59e0b" },
      "600": { "$type": "color", "$value": "#d97706" },
      "700": { "$type": "color", "$value": "#b45309" }
    },
    "red": {
      "50":  { "$type": "color", "$value": "#fef2f2" },
      "500": { "$type": "color", "$value": "#ef4444" },
      "600": { "$type": "color", "$value": "#dc2626" },
      "700": { "$type": "color", "$value": "#b91c1c" }
    }
  },
  "font": {
    "body":    { "$type": "fontFamily", "$value": "'Inter', system-ui, sans-serif" },
    "display": { "$type": "fontFamily", "$value": "'Satoshi', 'Inter', system-ui, sans-serif" },
    "mono":    { "$type": "fontFamily", "$value": "'JetBrains Mono', ui-monospace, monospace" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "4px" },
    "md":   { "$type": "dimension", "$value": "6px" },
    "lg":   { "$type": "dimension", "$value": "8px" },
    "xl":   { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "border": {
    "width": { "$type": "dimension", "$value": "1px" }
  },
  "duration": {
    "fast":  { "$type": "duration", "$value": "150ms" },
    "base":  { "$type": "duration", "$value": "200ms" },
    "slow":  { "$type": "duration", "$value": "300ms" }
  },
  "easing": {
    "default": { "$type": "cubicBezier", "$value": "cubic-bezier(.4,0,.2,1)" },
    "out":     { "$type": "cubicBezier", "$value": "cubic-bezier(0,0,.2,1)" },
    "in":      { "$type": "cubicBezier", "$value": "cubic-bezier(.4,0,1,1)" }
  },
  "semantic": {
    "light": {
      "canvas":          "#ffffff",
      "surface":         "#ffffff",
      "surface-raised":  "#ffffff",
      "surface-sunken":  "{color.n.100}",
      "surface-hover":   "{color.n.100}",
      "border":          "{color.n.200}",
      "border-strong":   "{color.n.300}",
      "text":            "{color.n.950}",
      "text-muted":      "{color.n.500}",
      "text-subtle":     "{color.n.400}",
      "accent":          "{color.blue.600}",
      "accent-hover":    "{color.blue.700}",
      "accent-subtle":   "{color.blue.50}",
      "on-accent":       "#ffffff",
      "danger":          "{color.red.600}",
      "danger-hover":    "{color.red.700}",
      "danger-subtle":   "{color.red.50}",
      "on-danger":       "#ffffff",
      "success":         "{color.green.600}",
      "success-subtle":  "{color.green.50}",
      "warning":         "{color.amber.600}",
      "warning-subtle":  "{color.amber.50}",
      "focus-ring":      "{color.blue.600}",
      "shadow-xs":       "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "shadow-sm":       "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
      "shadow-md":       "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
      "shadow-lg":       "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
    },
    "dark": {
      "canvas":          "{color.n.950}",
      "surface":         "{color.n.950}",
      "surface-raised":  "{color.n.900}",
      "surface-sunken":  "{color.n.900}",
      "surface-hover":   "{color.n.800}",
      "border":          "{color.n.800}",
      "border-strong":   "{color.n.700}",
      "text":            "{color.n.50}",
      "text-muted":      "{color.n.400}",
      "text-subtle":     "{color.n.500}",
      "accent":          "{color.blue.500}",
      "accent-hover":    "{color.blue.400}",
      "accent-subtle":   "{color.blue.950}",
      "on-accent":       "{color.n.950}",
      "danger":          "{color.red.500}",
      "danger-hover":    "#f87171",
      "danger-subtle":   "#450a0a",
      "on-danger":       "{color.n.950}",
      "success":         "{color.green.500}",
      "success-subtle":  "#052e16",
      "warning":         "{color.amber.500}",
      "warning-subtle":  "#451a03",
      "focus-ring":      "{color.blue.400}",
      "shadow-xs":       "0 1px 2px 0 rgb(0 0 0 / 0.4)",
      "shadow-sm":       "0 1px 3px 0 rgb(0 0 0 / 0.5), 0 1px 2px -1px rgb(0 0 0 / 0.5)",
      "shadow-md":       "0 4px 6px -1px rgb(0 0 0 / 0.5), 0 2px 4px -2px rgb(0 0 0 / 0.5)",
      "shadow-lg":       "0 10px 15px -3px rgb(0 0 0 / 0.5), 0 4px 6px -4px rgb(0 0 0 / 0.5)"
    }
  },
  "variants": {
    "showcase": {
      "light": {
        "accent":        "{color.violet.600}",
        "accent-hover":  "{color.violet.700}",
        "accent-subtle": "{color.violet.50}",
        "focus-ring":    "{color.violet.600}"
      },
      "dark": {
        "accent":        "{color.violet.500}",
        "accent-hover":  "{color.violet.400}",
        "accent-subtle": "{color.violet.950}",
        "focus-ring":    "{color.violet.400}"
      }
    }
  }
}
